---
import Layout from "../../layouts/Layout.astro";
import ChampionCard from "../../components/champion/ChampionCard.astro";
import { getRarityStyle } from "../../utils/rarity";
import { getAffinityStyle } from "../../utils/affinity";
import affinityIconsData from "../../data/assets/affinities.json";

// 1. Cargar Sets dinámicamente
const setFiles = import.meta.glob("../../data/sets/*.json", { eager: true });
const setsData: Record<string, any> = {};
Object.values(setFiles).forEach((file: any) => {
  const data = file.default || file;
  if (data.slug) setsData[data.slug] = data;
});

// Cargar Reliquias
const relicFiles = import.meta.glob("../../data/relics/*.json", { eager: true });
const relicsData: Record<string, any> = {};
Object.values(relicFiles).forEach((file: any) => {
  const data = file.default || file;
  if (data.slug) relicsData[data.slug] = data;
});

// Cargar Bendiciones
const blessingFiles = import.meta.glob("../../data/blessings/*.json", { eager: true });
const blessingsData: Record<string, any> = {};
Object.values(blessingFiles).forEach((file: any) => {
  const data = file.default || file;
  if (data.slug) blessingsData[data.slug] = data;
});

const affinityIcons = affinityIconsData as Record<string, string>;

// 1. Generar rutas
export async function getStaticPaths() {
  const championFiles = import.meta.glob("../../data/champions/*.json", {
    eager: true,
  });
  const champions = Object.values(championFiles).map(
    (file: any) => file.default || file,
  );

  return champions.map((champ: any) => ({
    params: { slug: champ.slug },
    props: { champ },
  }));
}

const { champ } = Astro.props;

// --- LÓGICA DE IMÁGENES NUEVA ---

// 1. Icono de Afinidad (Buscamos por nombre, ej: "Fuerza")
// Safe access with fallback
const affinityIcon = affinityIcons[champ.affinity] || null;

// 2. Iconos de Sets Recomendados
// champ.gear ahora es un array de strings ["letal", "velocidad"] gracias a la migración
// Ojo: Si alguno quedó como objeto {set_name: "x"}, lo manejamos por seguridad
const recommendedSets = (champ.gear || []).map((item: any) => {
  // Manejo híbrido por si acaso (string vs objeto antiguo)
  const setSlug = (
    typeof item === "string" ? item : item.set_name || ""
  ).toLowerCase();

  // Buscamos en el mapa de datos completo
  const setData = setsData[setSlug] || null;

  return {
    name: setData
      ? setData.name
      : setSlug.charAt(0).toUpperCase() + setSlug.slice(1),
    icon: setData ? setData.image : null,
    description: setData ? setData.description : "Sin descripción",
  };
});

// 2.a Iconos de Reliquias Recomendadas
const recommendedRelics = (champ.relics || []).map((item: any) => {
  const slug = (typeof item === "string" ? item : item.slug || "").toLowerCase();
  const data = relicsData[slug];
  return {
    name: data ? data.name : slug.replace(/_/g, " ").replace(/\b\w/g, (l: string) => l.toUpperCase()),
    icon: data ? data.image : null,
    description: data ? data.description : "Sin descripción"
  };
});

// 2.b Iconos de Bendiciones Recomendadas
const recommendedBlessings = (champ.blessings || []).map((item: any) => {
  const slug = (typeof item === "string" ? item : item.slug || "").toLowerCase();
  const data = blessingsData[slug];
  return {
    name: data ? data.name : slug.replace(/-/g, " ").replace(/\b\w/g, (l: string) => l.toUpperCase()),
    icon: data ? data.image : null,
    description: data ? data.description : "Sin descripción"
  };
});

// Helper de ordenamiento de libros
const getPriorityWeight = (p: string) => {
  p = p?.toLowerCase() || '';
  if (p.includes('máxima') || p.includes('max') || p.includes('alta')) return 3;
  if (p.includes('media') || p.includes('normal')) return 2;
  if (p.includes('baja') || p.includes('ninguna') || p.includes('no')) return 0;
  return 1;
};
const sortSkillsByPriority = (skills: any[]) => {
  if (!skills) return [];
  return [...skills].sort((a, b) => getPriorityWeight(b.book_priority) - getPriorityWeight(a.book_priority));
};

// 3. Artworks adicionales
// Ahora vienen directamente del JSON del campeón
const extraArtworks = champ.artworks || [];

// 4. Icono de Aura (si tienes la key en el json del champ)
// Asumimos que champ.aura_type o similar coincide con tu json de auras
// Si no tienes una key directa, puedes intentar machear por descripción o dejarlo pendiente.
//const auraIcon = champ.aura_key ? auraIcons[champ.aura_key] : null;

// --- TU LÓGICA DE ESTILOS ORIGINAL ---

// ... existing code ...

const affinityStyle = getAffinityStyle(champ.affinity);
const affinityClass = affinityStyle.text;

const rarityStyle = getRarityStyle(champ.rarity);
const rarityColorVar = rarityStyle.hex;
const rarityTextClass = rarityStyle.text;
---

<Layout title={`${champ.name} - El Tomo Legendario`}>
  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12 animate-fade-in">
      <div class="md:col-span-1 flex justify-center md:justify-end text-center">
        <div class="flex flex-col items-center w-fit mx-auto md:mx-0">
          <div class="relative group w-fit h-fit">
            <img
              src={`${champ.image}`}
              alt={champ.name}
              class={`w-full max-w-[280px] rounded-lg border-4 transition-all duration-300 group-hover:scale-105 relative z-10 shadow-2xl ${rarityStyle.border} hover:${rarityStyle.glow}`}
            />
          </div>

          {champ.rarity === 'Mítico' && champ.forms && champ.forms.length >= 2 && (
            <div class="flex flex-col items-center mt-6 w-full">
              <div class="flex gap-6 justify-center w-full px-4 mb-3">
                <button
                  class="form-toggle-btn active w-14 h-14 rounded-full font-bold text-2xl border-2 border-raid-gold bg-raid-gold/10 text-raid-gold hover:bg-raid-gold hover:text-black transition-all duration-300 shadow-lg shadow-raid-gold/30 flex items-center justify-center cursor-pointer"
                  data-target-form={champ.forms[0].id}
                >
                  I
                </button>
                <button
                  class="form-toggle-btn w-14 h-14 rounded-full font-bold text-2xl border-2 border-gray-600 bg-transparent text-gray-400 hover:border-raid-gold hover:text-raid-gold transition-all duration-300 flex items-center justify-center cursor-pointer"
                  data-target-form={champ.forms[1].id}
                >
                  II
                </button>
              </div>
              {champ.forms.map((form: any, index: number) => (
                <div 
                  class={`form-name-container text-sm font-bold text-raid-gold tracking-widest uppercase transition-opacity duration-300 ${index === 0 ? '' : 'hidden'}`} 
                  data-form-id={form.id}
                >
                  {form.name}
                </div>
              ))}
            </div>
          )}
        </div>
      </div>

      <div class="md:col-span-2 flex flex-col justify-start pl-0 md:pl-8">
        <h1
          class="text-5xl font-black text-raid-gold mb-4 uppercase tracking-tight flex items-center gap-4"
        >
          {champ.name}
          <!--
           {auraIcon && (
             <img src={`/${auraIcon}`} alt="Aura" class="w-10 h-10 object-contain" title="Aura de Líder" />
          )}
         -->
        </h1>

        <div class="flex flex-wrap gap-2 mb-6">
          <span
            class={`pl-2 pr-3 py-1 bg-raid-card rounded-full font-bold text-xs flex items-center gap-1 border border-gray-700 ${affinityClass}`}
          >
            {
              affinityIcon && (
                <img
                  src={`${affinityIcon}`}
                  class="w-4 h-4"
                  alt={champ.affinity}
                />
              )
            }
            {champ.affinity}
          </span>

          <span
            class={`px-3 py-1 bg-raid-card rounded-full font-bold text-xs ${rarityTextClass} border border-gray-700`}
          >
            {champ.rarity}
          </span>
          {champ.rarity === 'Mítico' && champ.forms ? (
            champ.forms.map((form: any, index: number) => {
              const types = champ.type ? champ.type.split("/") : [];
              const formType = types[index] || champ.type;
              return (
                <span
                  class={`form-type-container px-3 py-1 bg-raid-card rounded-full font-bold text-xs text-gray-300 border border-gray-700 ${index === 0 ? '' : 'hidden'}`}
                  data-form-id={form.id}
                >
                  {formType?.trim()}
                </span>
              );
            })
          ) : (
            <span
              class="px-3 py-1 bg-raid-card rounded-full font-bold text-xs text-gray-300 border border-gray-700"
            >
              {champ.type}
            </span>
          )}
          <span
            class="px-3 py-1 bg-raid-card rounded-full font-bold text-xs text-gray-400 border border-gray-700"
          >
            {champ.faction}
          </span>
        </div>

        <!-- <p
          class="text-gray-300 italic bg-raid-card p-4 rounded-lg border-l-4 mb-6 text-sm leading-relaxed"
          style={`border-color: ${rarityColorVar}`}
        >
          {champ.role || "Rol no definido en el tomo aún."}
        </p> -->

        <h3
          class="text-sm font-bold text-raid-gold mb-3 uppercase tracking-wider"
        >
          Estadísticas Base
        </h3>
        
        {champ.rarity === 'Mítico' && champ.forms ? (
          champ.forms.map((form: any, index: number) => (
            <div class={`form-stats-container grid grid-cols-2 md:grid-cols-4 gap-2 text-xs ${index === 0 ? '' : 'hidden'}`} data-form-id={form.id}>
              {
                [
                  { label: "HP", value: form.stats?.hp, color: "text-green-400" },
                  { label: "ATK", value: form.stats?.attack, color: "text-red-400" },
                  { label: "DEF", value: form.stats?.defense, color: "text-blue-400" },
                  { label: "VEL", value: form.stats?.speed, color: "text-yellow-400" },
                  { label: "P.CRIT", value: form.stats?.critRate + "%", color: "text-white" },
                  { label: "D.CRIT", value: form.stats?.critDamage + "%", color: "text-white" },
                  { label: "RES", value: form.stats?.resistance, color: "text-white" },
                  { label: "PUNT", value: form.stats?.accuracy, color: "text-white" },
                ].map((stat) => (
                  <div class="bg-raid-bg p-2 rounded border border-gray-700 hover:border-gray-500 transition-colors">
                    <p class="text-gray-500 uppercase font-bold text-[10px]">{stat.label}</p>
                    <p class={`font-mono font-bold text-sm ${stat.color}`}>{stat.value || 0}</p>
                  </div>
                ))
              }
            </div>
          ))
        ) : (
          <div class="grid grid-cols-2 md:grid-cols-4 gap-2 text-xs">
            {
              [
                { label: "HP", value: champ.stats?.hp, color: "text-green-400" },
                {
                  label: "ATK",
                  value: champ.stats?.attack,
                  color: "text-red-400",
                },
                {
                  label: "DEF",
                  value: champ.stats?.defense,
                  color: "text-blue-400",
                },
                {
                  label: "VEL",
                  value: champ.stats?.speed,
                  color: "text-yellow-400",
                },
                {
                  label: "P.CRIT",
                  value: champ.stats?.critRate + "%",
                  color: "text-white",
                },
                {
                  label: "D.CRIT",
                  value: champ.stats?.critDamage + "%",
                  color: "text-white",
                },
                {
                  label: "RES",
                  value: champ.stats?.resistance,
                  color: "text-white",
                },
                {
                  label: "PUNT",
                  value: champ.stats?.accuracy,
                  color: "text-white",
                },
              ].map((stat) => (
                <div class="bg-raid-bg p-2 rounded border border-gray-700 hover:border-gray-500 transition-colors">
                  <p class="text-gray-500 uppercase font-bold text-[10px]">
                    {stat.label}
                  </p>
                  <p class={`font-mono font-bold text-sm ${stat.color}`}>
                    {stat.value || 0}
                  </p>
                </div>
              ))
            }
          </div>
        )}
      </div>
    </div>

    <div class="mb-8 sticky top-0 z-40 bg-[#0a0e14]/95 backdrop-blur-sm pt-4">
      <div
        class="flex overflow-x-auto gap-2 border-b border-gray-700 pb-0 no-scrollbar"
        role="tablist"
      >
        <button
          data-tab="habilidades"
          class="tab-button active px-4 py-3 font-semibold border-b-2 border-raid-gold text-raid-gold whitespace-nowrap transition-colors"
        >
          Habilidades
        </button>
        <button
          data-tab="builds"
          class="tab-button px-4 py-3 font-semibold border-b-2 border-transparent text-gray-400 hover:text-white whitespace-nowrap transition-colors"
        >
          Builds & Equipo
        </button>
        <button
          data-tab="galeria"
          class="tab-button px-4 py-3 font-semibold border-b-2 border-transparent text-gray-400 hover:text-white whitespace-nowrap transition-colors"
        >
          Galería
        </button>
        <button
          data-tab="maestrias"
          class="tab-button px-4 py-3 font-semibold border-b-2 border-transparent text-gray-400 hover:text-white whitespace-nowrap transition-colors"
        >
          Maestrías
        </button>
        <button
          data-tab="libros"
          class="tab-button px-4 py-3 font-semibold border-b-2 border-transparent text-gray-400 hover:text-white whitespace-nowrap transition-colors"
        >
          Prioridad Libros
        </button>
        <button
          data-tab="modos"
          class="tab-button px-4 py-3 font-semibold border-b-2 border-transparent text-gray-400 hover:text-white whitespace-nowrap transition-colors"
        >
          Mejores Modos
        </button>
        <button
          data-tab="sinergias"
          class="tab-button px-4 py-3 font-semibold border-b-2 border-transparent text-gray-400 hover:text-white whitespace-nowrap transition-colors"
        >
          Sinergias
        </button>
        <button
          data-tab="proscontras"
          class="tab-button px-4 py-3 font-semibold border-b-2 border-transparent text-gray-400 hover:text-white whitespace-nowrap transition-colors"
        >
          Pros / Contras
        </button>
      </div>
    </div>

    <div class="space-y-8 min-h-[400px]">
      <section id="habilidades" class="tab-content">
        <h2 class="text-3xl font-bold mb-6 text-white flex items-center gap-2">
          ⚔️ Habilidades
        </h2>
        <div class="space-y-6">
          {champ.rarity === 'Mítico' && champ.forms ? (
            champ.forms.map((form: any, index: number) => (
              <div class={`form-skills-container space-y-6 ${index === 0 ? '' : 'hidden'}`} data-form-id={form.id}>
                {form.skills && form.skills.map((skill: any) => (
                  <div class="bg-raid-card p-6 rounded-lg border border-gray-700 hover:border-raid-gold transition-colors group">
                    <div class="flex justify-between items-start mb-3">
                      <div>
                        <h3 class="text-2xl font-bold text-raid-gold group-hover:text-white transition-colors">
                          {skill.name}
                        </h3>
                        <div class="flex gap-2 mt-1">
                          {skill.name?.toLowerCase().includes("pasiva") && (
                            <span class="text-xs bg-blue-900/50 text-blue-300 px-2 py-0.5 rounded border border-blue-800">
                              Pasiva
                            </span>
                          )}
                          {skill.cooldown && (
                            <span class="text-xs bg-gray-700 text-gray-300 px-2 py-0.5 rounded border border-gray-600">
                              Cooldown: {skill.cooldown} turnos
                            </span>
                          )}
                        </div>
                      </div>
                      {skill.multiplier && (
                        <span class="bg-black/30 text-xs px-3 py-1 rounded text-green-400 font-mono border border-gray-700">
                          DMG: {skill.multiplier}
                        </span>
                      )}
                    </div>
                    <p class="text-gray-300 leading-relaxed mb-4 whitespace-pre-line">
                      {skill.description}
                    </p>

                    {skill.levels && skill.levels.length > 0 && (
                      <div class="mt-4 pt-4 border-t border-gray-700/50">
                        <p class="text-xs text-gray-500 font-bold mb-2 uppercase">
                          Mejoras de libro:
                        </p>
                        <ul class="text-sm text-gray-400 space-y-1 grid grid-cols-1 md:grid-cols-2">
                          {skill.levels.map((level: any) => (
                            <li class="flex items-center gap-2">
                              <span class="w-1.5 h-1.5 rounded-full bg-raid-gold" />
                              {level.level_desc || level}
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            ))
          ) : (
            champ.skills &&
              champ.skills.map((skill: any) => (
                <div class="bg-raid-card p-6 rounded-lg border border-gray-700 hover:border-raid-gold transition-colors group">
                  <div class="flex justify-between items-start mb-3">
                    <div>
                      <h3 class="text-2xl font-bold text-raid-gold group-hover:text-white transition-colors">
                        {skill.name}
                      </h3>
                      <div class="flex gap-2 mt-1">
                        {skill.name?.toLowerCase().includes("pasiva") && (
                          <span class="text-xs bg-blue-900/50 text-blue-300 px-2 py-0.5 rounded border border-blue-800">
                            Pasiva
                          </span>
                        )}
                        {skill.cooldown && (
                          <span class="text-xs bg-gray-700 text-gray-300 px-2 py-0.5 rounded border border-gray-600">
                            Cooldown: {skill.cooldown} turnos
                          </span>
                        )}
                      </div>
                    </div>
                    {skill.multiplier && (
                      <span class="bg-black/30 text-xs px-3 py-1 rounded text-green-400 font-mono border border-gray-700">
                        DMG: {skill.multiplier}
                      </span>
                    )}
                  </div>
                  <p class="text-gray-300 leading-relaxed mb-4 whitespace-pre-line">
                    {skill.description}
                  </p>

                  {skill.levels && skill.levels.length > 0 && (
                    <div class="mt-4 pt-4 border-t border-gray-700/50">
                      <p class="text-xs text-gray-500 font-bold mb-2 uppercase">
                        Mejoras de libro:
                      </p>
                      <ul class="text-sm text-gray-400 space-y-1 grid grid-cols-1 md:grid-cols-2">
                        {skill.levels.map((level: any) => (
                          <li class="flex items-center gap-2">
                            <span class="w-1.5 h-1.5 rounded-full bg-raid-gold" />
                            {level.level_desc || level}
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>
              ))
          )}
        </div>
      </section>

      <section id="builds" class="tab-content hidden">
        <h2 class="text-3xl font-bold mb-6 text-white">
          🛡️ Builds y Equipamiento
        </h2>

        <div
          class="bg-raid-card p-6 rounded-lg border-l-4 border-raid-gold mb-6 shadow-lg"
        >
          <h3 class="text-xl font-bold text-raid-gold mb-4">
            Sets Recomendados
          </h3>
          <div class="flex flex-wrap gap-6">
            {
              recommendedSets.length > 0 ? (
                recommendedSets.map((set: any) => (
                  <div class="flex flex-col items-center gap-2">
                    <div class="w-16 h-16 bg-gray-900 rounded-lg p-2 border border-gray-600 flex items-center justify-center relative group cursor-help">
                      {set.icon ? (
                        <img
                          src={`${set.icon}`}
                          alt={set.name}
                          class="w-full h-full object-contain drop-shadow-md"
                        />
                      ) : (
                        <span class="text-xs text-gray-500 text-center">
                          {set.name}
                        </span>
                      )}
                      <div class="absolute bottom-full mb-2 bg-black text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-10">
                        {set.name}
                      </div>
                    </div>
                    <span class="text-xs text-gray-400 font-bold uppercase tracking-wider text-center max-w-[5rem] truncate">
                      {set.name}
                    </span>
                  </div>
                ))
              ) : (
                <p class="text-gray-400 italic">
                  No hay sets específicos registrados en el tomo.
                </p>
              )
            }
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          <div
            class="bg-raid-card p-6 rounded-lg border-l-4 border-raid-purple shadow-lg"
          >
            <h3 class="text-xl font-bold text-raid-purple mb-4">
              Reliquias Recomendadas
            </h3>
            <div class="flex flex-wrap gap-6">
              {
                recommendedRelics.length > 0 ? (
                  recommendedRelics.map((set: any) => (
                    <div class="flex flex-col items-center gap-2">
                      <div class="w-16 h-16 bg-gray-900 rounded-lg p-2 border border-gray-600 flex items-center justify-center relative group cursor-help">
                        {set.icon ? (
                          <img
                            src={`${set.icon}`}
                            alt={set.name}
                            class="w-full h-full object-contain drop-shadow-md"
                          />
                        ) : (
                          <span class="text-xs text-gray-500 text-center">
                            {set.name}
                          </span>
                        )}
                        <div class="absolute bottom-full mb-2 bg-black text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-10">
                          {set.name}
                        </div>
                      </div>
                      <span class="text-xs text-gray-400 font-bold uppercase tracking-wider text-center max-w-[5rem] truncate">
                        {set.name}
                      </span>
                    </div>
                  ))
                ) : (
                  <p class="text-gray-400 italic">
                    Sin recomendaciones de reliquias.
                  </p>
                )
              }
            </div>
          </div>

          <div
            class="bg-raid-card p-6 rounded-lg border-l-4 border-blue-500 shadow-lg"
          >
            <h3 class="text-xl font-bold text-blue-500 mb-4">
              Bendiciones Recomendadas
            </h3>
            <div class="flex flex-wrap gap-6">
              {
                recommendedBlessings.length > 0 ? (
                  recommendedBlessings.map((set: any) => (
                    <div class="flex flex-col items-center gap-2">
                      <div class="w-16 h-16 bg-gray-900 rounded-lg p-2 border border-gray-600 flex items-center justify-center relative group cursor-help">
                        {set.icon ? (
                          <img
                            src={`${set.icon}`}
                            alt={set.name}
                            class="w-full h-full object-contain drop-shadow-md scale-125"
                          />
                        ) : (
                          <span class="text-xs text-gray-500 text-center">
                            {set.name}
                          </span>
                        )}
                        <div class="absolute bottom-full mb-2 bg-black text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-10">
                          {set.name}
                        </div>
                      </div>
                      <span class="text-xs text-gray-400 font-bold uppercase tracking-wider text-center max-w-[5rem] truncate">
                        {set.name}
                      </span>
                    </div>
                  ))
                ) : (
                  <p class="text-gray-400 italic">
                    Sin recomendaciones de bendiciones.
                  </p>
                )
              }
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-raid-card p-6 rounded-lg border border-gray-700">
            <h3 class="text-xl font-bold text-white mb-4">
              Stats Prioritarios (PvE)
            </h3>
            <ul class="space-y-3 text-sm text-gray-300">
              {champ.pve_stats && champ.pve_stats.length > 0 ? (
                champ.pve_stats.map((stat: string) => (
                  <li class="flex items-center gap-2 border-b border-gray-700 pb-2">
                    <span class="text-raid-gold font-bold">✓</span> {stat}
                  </li>
                ))
              ) : (
                <li class="text-gray-500 italic">No hay información de stats PvE</li>
              )}
            </ul>
          </div>
          <div class="bg-raid-card p-6 rounded-lg border border-gray-700">
            <h3 class="text-xl font-bold text-white mb-4">
              Stats Prioritarios (PvP)
            </h3>
            <ul class="space-y-3 text-sm text-gray-300">
              {champ.pvp_stats && champ.pvp_stats.length > 0 ? (
                champ.pvp_stats.map((stat: string) => (
                  <li class="flex items-center gap-2 border-b border-gray-700 pb-2">
                    <span class="text-raid-gold font-bold">✓</span> {stat}
                  </li>
                ))
              ) : (
                <li class="text-gray-500 italic">No hay información de stats PvP</li>
              )}
            </ul>
          </div>
        </div>
      </section>

      <section id="galeria" class="tab-content hidden">
        <h2 class="text-3xl font-bold mb-6 text-white">🎨 Galería de Arte</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div
            class="group relative overflow-hidden rounded-lg border border-gray-700 hover:border-raid-gold transition-all duration-300 lg:col-span-1 lg:row-span-2 shadow-xl"
          >
            <img
              src={`${champ.image}`}
              alt={champ.name}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-100"
            >
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <p class="text-raid-gold font-bold text-lg">Ilustración Base</p>
            </div>
          </div>

          {
            extraArtworks.length > 0 ? (
              extraArtworks.map((art: string, i: number) => (
                <div class="group relative overflow-hidden rounded-lg border border-gray-700 hover:border-blue-500 transition-all duration-300 aspect-[3/4] cursor-pointer">
                  <img
                    src={`${art}`}
                    alt={`Arte ${i}`}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              ))
            ) : (
              // Placeholder si no hay extra artworks
              <div class="col-span-1 md:col-span-2 bg-raid-card/30 border border-dashed border-gray-700 rounded-lg flex flex-col items-center justify-center p-12 text-center">
                <span class="text-4xl mb-2 opacity-50">🖼️</span>
                <p class="text-gray-500">
                  No hay ilustraciones adicionales disponibles.
                </p>
              </div>
            )
          }
        </div>
      </section>

      <section id="maestrias" class="tab-content hidden">
        <h2 class="text-3xl font-bold mb-6 text-white">Maestrías</h2>
        {champ.masteries && champ.masteries.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 w-full max-w-4xl mx-auto">
            {champ.masteries.map((mastery: any) => (
              <div class="bg-raid-card border border-gray-700 rounded-lg p-6 shadow-xl flex flex-col items-center">
                <div class="w-full flex-grow flex justify-center items-center h-full">
                  {mastery.selected_masteries && mastery.selected_masteries.map((sm: any) => (
                     <img 
                      src={sm.mastery_image} 
                      alt={`Maestría ${mastery.branch}`} 
                      class="max-w-[320px] w-full h-[auto] rounded shadow-lg border border-gray-800 object-contain hover:scale-105 transition-transform duration-500" 
                      loading="lazy"
                    />
                  ))}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div
            class="bg-raid-bg p-8 rounded-lg border border-gray-700 text-center"
          >
            <p class="text-gray-400 mb-6">
              El árbol de maestrías óptimo está siendo analizado por nuestros
              expertos.
            </p>
            <div
              class="inline-block bg-gray-800 px-6 py-4 rounded border border-gray-600"
            >
              <span class="text-2xl">🚧</span>
              <span class="font-bold text-white ml-2">Próximamente</span>
            </div>
          </div>
        )}
      </section>

      <section id="libros" class="tab-content hidden">
        <h2 class="text-3xl font-bold mb-6 text-white">
          📚 Prioridad de Libros
        </h2>
        <div class="space-y-4">
          {champ.rarity === 'Mítico' && champ.forms ? (
            champ.forms.map((form: any, index: number) => (
              <div class={`form-books-container space-y-4 ${index === 0 ? '' : 'hidden'}`} data-form-id={form.id}>
                {sortSkillsByPriority(form.skills).map((skill: any, sIndex: number) => (
                  <div class="bg-raid-card p-4 rounded-lg border border-gray-700 flex items-center gap-4">
                    <div
                      class={`p-3 rounded-lg font-bold w-12 h-12 flex items-center justify-center text-lg ${getPriorityWeight(skill.book_priority) >= 3 ? "bg-raid-gold text-black" : "bg-gray-800 text-gray-500"}`}
                    >
                      {sIndex + 1}
                    </div>
                    <div class="flex-1">
                      <h3 class="font-bold text-white text-lg">{skill.name}</h3>
                      <p class="text-gray-400 text-sm flex items-center gap-2">
                        Prioridad: <span class="text-raid-gold font-bold">{skill.book_priority || "Ninguna"}</span>
                      </p>
                    </div>
                  </div>
                ))}
              </div>
            ))
          ) : (
            sortSkillsByPriority(champ.skills).map((skill: any, index: number) => (
              <div class="bg-raid-card p-4 rounded-lg border border-gray-700 flex items-center gap-4">
                <div
                  class={`p-3 rounded-lg font-bold w-12 h-12 flex items-center justify-center text-lg ${getPriorityWeight(skill.book_priority) >= 3 ? "bg-raid-gold text-black" : "bg-gray-800 text-gray-500"}`}
                >
                  {index + 1}
                </div>
                <div class="flex-1">
                  <h3 class="font-bold text-white text-lg">{skill.name}</h3>
                  <p class="text-gray-400 text-sm flex items-center gap-2">
                    Prioridad: <span class="text-raid-gold font-bold">{skill.book_priority || "Ninguna"}</span>
                  </p>
                </div>
              </div>
            ))
          )}
        </div>
      </section>

      <section id="modos" class="tab-content hidden">
        <h2 class="text-3xl font-bold mb-6 text-white">
          Mejores Modos de Juego
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {champ.game_modes && champ.game_modes.length > 0 ? (
            champ.game_modes.map((mode: any) => (
              <div class="bg-gradient-to-br from-gray-900/60 to-transparent p-6 rounded-lg border border-gray-700/80">
                <h3 class="text-raid-gold font-bold text-lg mb-2 flex justify-between items-center">
                  {mode.area} <span class="text-xs text-gray-400 font-normal">{mode.dificultad || ''}</span>
                </h3>
                <div class="w-full bg-gray-800 h-2 rounded-full mb-2 overflow-hidden border border-gray-700">
                  <div class="bg-linear-to-r from-raid-gold to-raid-purple h-2 rounded-full" style={`width: ${(parseFloat(mode.calificacion)/5)*100}%`}></div>
                </div>
                <p class="text-gray-300 font-semibold text-sm">Rating: <span class="text-raid-gold font-bold">{mode.calificacion} / 5</span></p>
              </div>
            ))
          ) : (
            <p class="text-gray-500 italic col-span-3 text-center">Aún no hay calificaciones para Modos de Juego</p>
          )}
        </div>
      </section>

      <section id="sinergias" class="tab-content hidden">
        <h2 class="text-3xl font-bold mb-6 text-white">🤝 Sinergias de Equipo</h2>
        {champ.sinergias && champ.sinergias.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 justify-items-center">
             {champ.sinergias.map((sinergia: string) => (
                <div class="flex flex-col items-center w-full">
                   <ChampionCard slug={sinergia} />
                </div>
             ))}
          </div>
        ) : (
          <div class="bg-raid-card p-8 rounded-lg border border-gray-700 text-center">
            <p class="text-gray-400">Este campeón no tiene sinergias registradas o trabaja bien de forma independiente.</p>
          </div>
        )}
      </section>

      <section id="proscontras" class="tab-content hidden">
        <h2 class="text-3xl font-bold mb-6 text-white">Balance del Campeón</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-green-900/10 p-6 rounded-xl border border-green-900/50 shadow-lg">
            <h3 class="text-2xl font-bold text-green-400 mb-4 flex items-center gap-2">
              <span>✅</span> Ventajas
            </h3>
            <ul class="space-y-3 text-sm text-gray-300">
              {champ.pros && champ.pros.length > 0 ? (
                champ.pros.map((pro: any) => (
                  <li class="flex items-start gap-3">
                    <span class="text-green-500 font-bold mt-0.5">+</span> {typeof pro === 'string' ? pro : pro.pro_item}
                  </li>
                ))
              ) : (
                <li class="text-gray-500 italic">Sin ventajas registradas</li>
              )}
            </ul>
          </div>

          <div class="bg-red-900/10 p-6 rounded-xl border border-red-900/50 shadow-lg">
            <h3 class="text-2xl font-bold text-red-400 mb-4 flex items-center gap-2">
              <span>❌</span> Desventajas
            </h3>
            <ul class="space-y-3 text-sm text-gray-300">
              {champ.contras && champ.contras.length > 0 ? (
                champ.contras.map((contra: any) => (
                  <li class="flex items-start gap-3">
                    <span class="text-red-500 font-bold mt-0.5">-</span> {typeof contra === 'string' ? contra : contra.contra_item}
                  </li>
                ))
              ) : (
                <li class="text-gray-500 italic">Sin desventajas registradas</li>
              )}
            </ul>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script>
    // Script para manejar los botones de Forma Mítica
    document.querySelectorAll<HTMLElement>(".form-toggle-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const targetForm = btn.dataset.targetForm;
        if (!targetForm) return;

        // Actualizar estilos de los botones (indicando cuál está activo)
        document.querySelectorAll<HTMLElement>(".form-toggle-btn").forEach(b => {
          if (b === btn) {
            b.classList.add("active", "border-raid-gold", "text-raid-gold", "shadow-lg", "bg-raid-gold/10");
            b.classList.remove("border-gray-600", "text-gray-400", "bg-transparent");
          } else {
            b.classList.remove("active", "border-raid-gold", "text-raid-gold", "shadow-lg", "bg-raid-gold/10");
            b.classList.add("border-gray-600", "text-gray-400", "bg-transparent");
          }
        });

        // Mostrar / Ocultar contenedores de habilidades, stats, libros, nombres, tipos
        const containers = [".form-type-container", ".form-name-container", ".form-stats-container", ".form-skills-container", ".form-books-container"];
        containers.forEach(containerSelector => {
          document.querySelectorAll<HTMLElement>(containerSelector).forEach(c => {
            if (c.dataset.formId === targetForm) {
              c.classList.remove("hidden");
            } else {
              c.classList.add("hidden");
            }
          });
        });
      });
    });

    // Tu Script Original de Tabs (Funciona Perfecto)
    document.querySelectorAll<HTMLElement>(".tab-button").forEach((button) => {
      button.addEventListener("click", () => {
        const tabName = button.dataset.tab;
        if (!tabName) return;

        // Reset tabs buttons
        document.querySelectorAll<HTMLElement>(".tab-button").forEach((btn) => {
          btn.classList.remove("active", "border-raid-gold", "text-raid-gold");
          btn.classList.add("border-transparent", "text-gray-400");
        });

        // Hide contents
        document
          .querySelectorAll<HTMLElement>(".tab-content")
          .forEach((content) => {
            content.classList.add("hidden");
          });

        // Activate current
        button.classList.add("active", "border-raid-gold", "text-raid-gold");
        button.classList.remove("border-transparent", "text-gray-400");

        const tabElement = document.getElementById(tabName);
        if (tabElement) {
          tabElement.classList.remove("hidden");
          // Pequeño scroll suave si la tab está muy abajo
          tabElement.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }
      });
    });
  </script>
</Layout>

<style>
  /* Animación simple de entrada */
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  /* Ocultar scrollbar en tabs pero permitir scroll */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

---
// Header component for El Tomo Legendario
import SearchBar from "./ui/SearchBar";
import ActiveEvents from "./ui/ActiveEvents";

// Cargar la data de los campeones para el buscador en tiempo real
const championFiles = import.meta.glob("../data/champions/*.json", { eager: true });
const searchData = Object.values(championFiles).map((file: any) => {
  const data = file.default || file;
  return {
    slug: data.slug,
    name: data.name,
    image: data.image
  };
});
---

<header class="bg-raid-bg border-b border-gray-700 sticky top-0 z-50">
    <!-- Top banner for events and promo code -->
    <div class="bg-raid-card border-b border-gray-800 py-1.5 px-4 sm:px-6 lg:px-8">
        <div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center text-sm gap-2 sm:gap-0">
            <!-- Active Events Island -->
            <ActiveEvents client:load eventName="Fusión: Héroe Mítico" />
            
            <!-- Promo Code Component (HTML) -->
            <button id="promo-code-btn" class="flex items-center gap-2 group cursor-pointer transition-colors relative" title="Click para copiar" aria-label="Copiar código promocional">
                <span class="text-gray-400 text-xs sm:text-sm font-semibold">Nuevo Código:</span>
                <div class="relative flex items-center justify-center">
                    <div class="bg-raid-bg border border-raid-purple/50 px-3 py-0.5 rounded-full text-raid-purple font-bold tracking-wider group-hover:bg-raid-purple/20 group-hover:border-raid-purple transition-all shadow-[0_0_8px_rgba(168,85,247,0.2)] text-xs sm:text-sm flex items-center gap-2">
                        <span id="promo-code-text">LEGENDARY2026</span>
                        <svg id="promo-copy-icon" class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                        <svg id="promo-success-icon" class="w-3 h-3 text-green-400 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <!-- Tooltip feedback -->
                    <span id="promo-tooltip" class="absolute -top-8 bg-gray-800 border border-gray-600 text-green-400 text-[10px] sm:text-xs px-2 py-1 rounded opacity-0 transition-all duration-300 shadow-lg pointer-events-none transform translate-y-2 whitespace-nowrap">¡Copiado!</span>
                </div>
            </button>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <!-- Logo/Brand -->
            <div class="shrink-0">
                <a href="/" class="flex items-center gap-2 group">
                    <div
                        class="text-2xl font-black bg-linear-to-r from-raid-gold to-raid-purple bg-clip-text text-transparent"
                    >
                        <img
                            src="/favicon.png"
                            alt="El Tomo Legendario Logo"
                            class="w-8 h-8 object-contain"
                        />
                    </div>
                    <span
                        class="text-lg font-bold text-white group-hover:text-raid-gold transition-colors"
                    >
                        El Tomo Legendario
                    </span>
                </a>
            </div>

            <!-- Navigation Links -->
            <nav
                class="hidden md:flex items-center justify-center flex-1 gap-8"
            >
                <a
                    href="/"
                    class="text-gray-300 hover:text-raid-gold transition-colors text-sm font-semibold"
                >
                    Home
                </a>
                <a
                    href="/facciones"
                    class="text-gray-300 hover:text-raid-purple transition-colors text-sm font-semibold"
                >
                    Facciones
                </a>
                <a
                    href="/guias"
                    class="text-gray-300 hover:text-raid-blue transition-colors text-sm font-semibold"
                >
                    Guías
                </a>
                <a
                    href="#"
                    class="text-gray-300 hover:text-raid-gold transition-colors text-sm font-semibold"
                >
                    Comunidad
                </a>
            </nav>

            <!-- Search & CTA Button -->
            <div class="flex items-center gap-4">
                <div class="hidden lg:block">
                    <SearchBar client:load champs={searchData} />
                </div>
                <a
                    href="/campeones"
                    class="hidden sm:inline-block px-4 py-2 bg-raid-gold text-raid-bg font-bold text-sm rounded-lg hover:shadow-lg hover:shadow-raid-gold/50 transition-all duration-300 whitespace-nowrap"
                >
                    Explorar
                </a>

                <!-- Mobile Menu Button -->
                <button
                    id="mobile-menu-btn"
                    class="md:hidden p-2 rounded-lg hover:bg-raid-card transition-colors text-raid-gold"
                    aria-label="Toggle menu"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Menu (Hidden by default) -->
        <div
            id="mobile-menu"
            class="hidden md:hidden bg-raid-card border-t border-gray-700 animate-fade-in absolute top-16 left-0 right-0 shadow-xl z-50"
        >
            <nav class="flex flex-col p-4 space-y-4">
                <a
                    href="/"
                    class="text-gray-300 hover:text-raid-gold transition-colors font-semibold block py-2 border-b border-gray-700/50"
                >
                    Home
                </a>
                <a
                    href="/facciones"
                    class="text-gray-300 hover:text-raid-purple transition-colors font-semibold block py-2 border-b border-gray-700/50"
                >
                    Facciones
                </a>
                <a
                    href="/guias"
                    class="text-gray-300 hover:text-raid-blue transition-colors font-semibold block py-2 border-b border-gray-700/50"
                >
                    Guías
                </a>
                <a
                    href="#"
                    class="text-gray-300 hover:text-raid-gold transition-colors font-semibold block py-2"
                >
                    Comunidad
                </a>
                <div class="pt-2">
                    <SearchBar client:load champs={searchData} />
                </div>
                <a
                    href="/campeones"
                    class="inline-block w-full text-center px-4 py-3 bg-raid-gold text-raid-bg font-bold rounded-lg hover:shadow-lg hover:shadow-raid-gold/50 transition-all duration-300 mt-2"
                >
                    Explorar Campeones
                </a>
            </nav>
        </div>
    </div>

    <script is:inline>
        const btn = document.getElementById("mobile-menu-btn");
        const menu = document.getElementById("mobile-menu");

        if (btn && menu) {
            btn.addEventListener("click", () => {
                menu.classList.toggle("hidden");
            });
        }

        // Funcionalidad para copiar el código promocional
        const promoBtn = document.getElementById("promo-code-btn");
        const promoText = document.getElementById("promo-code-text");
        const copyIcon = document.getElementById("promo-copy-icon");
        const successIcon = document.getElementById("promo-success-icon");
        const tooltip = document.getElementById("promo-tooltip");

        if (promoBtn && promoText && copyIcon && successIcon && tooltip) {
            promoBtn.addEventListener("click", async () => {
                try {
                    await navigator.clipboard.writeText(promoText.textContent.trim());
                    
                    // Mostrar éxito
                    copyIcon.classList.add("hidden");
                    successIcon.classList.remove("hidden");
                    tooltip.classList.remove("opacity-0", "translate-y-2");
                    tooltip.classList.add("opacity-100", "translate-y-0");
                    
                    // Restaurar después de 2 segundos
                    setTimeout(() => {
                        successIcon.classList.add("hidden");
                        copyIcon.classList.remove("hidden");
                        tooltip.classList.remove("opacity-100", "translate-y-0");
                        tooltip.classList.add("opacity-0", "translate-y-2");
                    }, 2000);
                } catch (err) {
                    console.error("Error al copiar: ", err);
                }
            });
        }
    </script>
</header>

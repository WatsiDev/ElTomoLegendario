---
import { Image } from "astro:assets";
import { getRarityStyle } from "../../utils/rarity";

// Soportamos tanto pasar `slug` directamente como el objeto `champion` por retrocompatibilidad
const slug = Astro.props.slug || Astro.props.champion?.slug;

if (!slug) {
  throw new Error("ChampionCard requiere la prop 'slug' o 'champion.slug'");
}

// Obtener la información del campeón desde el archivo JSON
const championPath = `/src/data/champions/${slug}.json`;
const championsGlob = import.meta.glob<{
  default: {
    name: string;
    rarity: string;
    slug: string;
    faction: string;
    image: string;
  };
}>('/src/data/champions/*.json');

if (!championsGlob[championPath]) {
  throw new Error(`Datos no encontrados para el campeón: ${slug}`);
}

const championData = await championsGlob[championPath]();
const { name, rarity, faction, image } = championData.default;

// Obtener la imagen con import.meta.glob para que Astro Image la optimice dinámicamente
const imagePath = image;
const imagesGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/champions/*.{jpeg,jpg,png,gif,webp}');

if (!imagesGlob[imagePath]) {
  throw new Error(`Imagen no encontrada para el campeón: ${slug}`);
}

const imageSrc = (await imagesGlob[imagePath]()).default;

const style = getRarityStyle(rarity);
const borderClass = `${style.border} ${style.glow}`;
---

<a href={`/campeon/${slug}`} class="group w-fit mx-auto flex flex-col">
  <div
    class={`relative bg-raid-card border ${borderClass} rounded-lg overflow-hidden transition-all duration-500 hover:-translate-y-1 w-fit`}
  >
    <div
      class="absolute inset-0 bg-linear-to-t from-raid-bg via-transparent to-transparent z-10 opacity-70"
    >
    </div>

    <Image
      src={imageSrc}
      alt={name}
      class="w-32 h-auto object-cover transition-transform duration-700 group-hover:scale-105 z-0 display-block"
      loading="lazy"
      width={128}
      height={128}
    />

    <div class="absolute bottom-0 left-0 right-0 p-2 z-20 text-center">
      <p
        class={`text-[7px] ${style.text} font-bold uppercase tracking-widest mb-0.5`}
      >
        {rarity}
      </p>
      <h3
        class="text-white font-bold text-[9px] leading-tight group-hover:text-raid-gold transition-colors line-clamp-2"
      >
        {name}
      </h3>
      <p class="text-gray-400 text-[6px] line-clamp-1">{faction}</p>
    </div>
  </div>
</a>
